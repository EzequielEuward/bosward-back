# ─── Base de datos (PostgreSQL) ───────────────────────────
# Opción A — Producción (Render): un solo connection string.
#   Si DATABASE_URL está definida, se ignoran las variables sueltas de abajo.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Opción B — Desarrollo local (docker-compose):
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=secret
DB_DATABASE=ward_perfumes

DB_SSL=false       # ⚠️ Poner en true en Render (conexión externa exige SSL)
DB_SYNC=true       # ⚠️ true crea el esquema solo. En producción real: false + migraciones

# ─── Firebase Admin SDK ───────────────────────────────────
# En local podés usar el archivo firebase-service-account.json en la raíz.
# En producción (Render) usá estas 3 variables:
FIREBASE_PROJECT_ID=tu-proyecto
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@tu-proyecto.iam.gserviceaccount.com
# La private key va entre comillas y con los saltos de línea escapados como \n
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Cloudinary ───────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── App ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Orígenes permitidos para CORS, separados por coma.
# En producción: la URL de tu sitio en Netlify, ej: https://bosward.netlify.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Migración de datos (solo para scripts/migrate-db.ts) ──
# URL del Postgres DESTINO (External Database URL de Render).
# El ORIGEN MySQL local se toma de SOURCE_DB_* (o sus defaults).
# TARGET_DATABASE_URL=postgresql://user:pass@host:5432/dbname
# SOURCE_DB_HOST=localhost
# SOURCE_DB_PORT=3306
# SOURCE_DB_USERNAME=root
# SOURCE_DB_PASSWORD=secret
# SOURCE_DB_DATABASE=ward_perfumes
